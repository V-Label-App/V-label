{
	"info": {
		"_postman_id": "validation-test-123",
		"name": "V-Label Validation Rules Test",
		"description": "Test suite for checking Zod validation rules (Password complexity, Phone format, Name constraints)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "❌ Register - Weak Password (No Special Char)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Should return 400\", function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"pm.test(\"Error should mention special character\", function () {",
							"    var jsonData = pm.response.json();",
							"    var specialCharError = jsonData.details.find(e => e.message.includes(\"special character\"));",
							"    pm.expect(specialCharError).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"valid.user@example.com\",\n    \"password\": \"Admin1234\",\n    \"fullName\": \"Valid Name\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/auth/register",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"auth",
						"register"
					]
				}
			},
			"response": []
		},
		{
			"name": "❌ Register - Weak Password (No Number)",
			"request": {
				"method": "POST",
				"header": [],
