generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                @id @default(uuid()) @db.Uuid
  email                  String                @unique @db.VarChar(255)
  passwordHash           String?               @map("password_hash") @db.VarChar(255)
  provider               AuthProvider          @default(LOCAL)
  fullName               String?               @map("full_name") @db.VarChar(255)
  avatarUrl              String?               @map("avatar_url") @db.VarChar(512)
  phoneNumber            String?               @map("phone_number") @db.VarChar(20)
  role                   UserRole              @default(ANNOTATOR)
  isActive               Boolean               @default(false) @map("is_active")
  reputationScore        Float                 @default(0) @map("reputation_score")
  totalTasksDone         Int                   @default(0) @map("total_tasks_done")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  googleId               String?               @unique @map("google_id") @db.VarChar(255)
  avatarPublicId         String?               @map("avatar_public_id") @db.VarChar(255)
  consensusVerified      AnnotationConsensus[] @relation("ConsensusVerifier")
  chatMessagesSent       ChatMessage[]         @relation("ChatSender")
  datasetsUploaded       Dataset[]             @relation("DatasetUploader")
  exportsGenerated       Export[]              @relation("Exporter")
  imagesUploaded         Image[]               @relation("ImageUploader")
  labelRequestsSent      LabelRequest[]        @relation("LabelRequester")
  labelRequestsReviewed  LabelRequest[]        @relation("LabelReviewer")
  labelCategoriesCreated LabelCategory[]       @relation("LabelCategoryCreator")
  labelsCreated          Label[]               @relation("LabelCreator")
  notifications          Notification[]
  passwordResetTokens    PasswordResetToken[]
  projectsJoined         ProjectMember[]
  taskActivities         TaskActivity[]
  tasksAssigned          TaskAssignment[]      @relation("Annotator")
  taskAssignmentsGiven   TaskAssignment[]      @relation("TaskAssigner")
  tasksReviewed          TaskAssignment[]      @relation("Reviewer")
  reassignmentsTo        TaskReassignment[]    @relation("NewAnnotator")
  reassignmentsFrom      TaskReassignment[]    @relation("OldAnnotator")
  reassignmentsTriggered TaskReassignment[]    @relation("Reassigner")
  workloads              UserWorkload[]

  @@map("users")
}

model Project {
  id                 String           @id @default(uuid()) @db.Uuid
  name               String           @db.VarChar(255)
  description        String?
  labelConfig        Json             @default("[]") @map("label_config")
  deadline           DateTime?
  enableAiAssistance Boolean          @default(false) @map("enable_ai_assistance")
  status             ProjectStatus    @default(ACTIVE)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  categoryId         String?          @map("category_id") @db.Uuid
  qualitySettings    Json?            @map("quality_settings")
  assignmentRule     AssignmentRule?
  chatMessages       ChatMessage[]
  datasets           Dataset[]
  exports            Export[]
  images             Image[]
  labelRequests      LabelRequest[]
  projectLabels      ProjectLabel[]
  members            ProjectMember[]
  category           ProjectCategory? @relation(fields: [categoryId], references: [id])
  taskActivities     TaskActivity[]
  tasks              Task[]
  userWorkloads      UserWorkload[]

  @@map("projects")
}

model ProjectMember {
  id          String      @id @default(uuid()) @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  joinedAt    DateTime    @default(now()) @map("joined_at")
  projectRole ProjectRole @default(ANNOTATOR) @map("project_role")
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectRole])
  @@map("project_members")
}

model Task {
  id              String               @id @default(uuid()) @db.Uuid
  projectId       String               @map("project_id") @db.Uuid
  imageUrl        String?              @map("image_url")
  status          TaskStatus           @default(TODO)
  imageId         String?              @map("image_id") @db.Uuid
  priority        TaskPriority         @default(MEDIUM)
  deadline        DateTime?
  difficultyLevel DifficultyLevel      @default(NORMAL) @map("difficulty_level")
  consensus       AnnotationConsensus?
  activities      TaskActivity[]
  assignments     TaskAssignment[]
  reassignments   TaskReassignment[]
  image           Image?               @relation(fields: [imageId], references: [id], onDelete: Cascade)
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@index([priority, deadline])
  @@map("tasks")
}

model TaskAssignment {
  id                   String           @id @default(uuid()) @db.Uuid
  taskId               String           @map("task_id") @db.Uuid
  annotatorId          String           @map("annotator_id") @db.Uuid
  reviewerId           String?          @map("reviewer_id") @db.Uuid
  status               AssignmentStatus @default(ASSIGNED)
  deadline             DateTime?
  annotations          Json?
  isAiGenerated        Boolean          @default(false) @map("is_ai_generated")
  annotatorNote        String?          @map("annotator_note")
  reviewScore          Int?             @map("review_score")
  reviewComment        String?          @map("review_comment")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  aiModelId            String?          @map("ai_model_id") @db.Uuid
  aiConfidence         Float?           @map("ai_confidence")
  reviewedAt           DateTime?        @map("reviewed_at")
  rejectionCount       Int              @default(0) @map("rejection_count")
  maxRejections        Int              @default(3) @map("max_rejections")
  skipReason           String?          @map("skip_reason")
  estimatedTimeMinutes Int?             @map("estimated_time_minutes")
  actualTimeSeconds    Int?             @map("actual_time_seconds")
  assignedBy           String?          @map("assigned_by") @db.Uuid
  assignmentMethod     AssignmentMethod @default(MANUAL) @map("assignment_method")
  aiModel              AiModel?         @relation(fields: [aiModelId], references: [id])
  annotator            User             @relation("Annotator", fields: [annotatorId], references: [id])
  assigner             User?            @relation("TaskAssigner", fields: [assignedBy], references: [id])
  reviewer             User?            @relation("Reviewer", fields: [reviewerId], references: [id])
  task                 Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submissionHistory    TaskSubmissionHistory[]

  @@index([aiModelId])
  @@map("task_assignments")
}

model TaskSubmissionHistory {
  id               String           @id @default(uuid()) @db.Uuid
  assignmentId     String           @map("assignment_id") @db.Uuid
  submissionNumber Int              @map("submission_number")
  annotations      Json?
  reviewComment    String?          @map("review_comment")
  status           AssignmentStatus
  submittedAt      DateTime         @default(now()) @map("submitted_at")
  reviewedAt       DateTime?        @map("reviewed_at")
  assignment       TaskAssignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("task_submission_histories")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String
  metadata  Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender    User     @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("chat_messages")
}

model NotificationTemplate {
  id              String           @id @default(uuid()) @db.Uuid
  type            NotificationType @unique
  titleTemplate   String           @map("title_template") @db.VarChar(255)
  messageTemplate String           @map("message_template")
  variables       Json
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("notification_templates")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String   @db.VarChar(255)
  actorId   String   @map("actor_id") @db.Uuid
  targetId  String?  @map("target_id") @db.Uuid
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model EmailTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   @unique @db.VarChar(100)
  subject   String   @db.VarChar(255)
  htmlBody  String   @map("html_body")
  textBody  String?  @map("text_body")
  variables Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@map("email_templates")
}

model EmailConfig {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  provider  String   @db.VarChar(50)
  config    Json
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_configs")
}

model EmailLog {
  id           String    @id @default(uuid()) @db.Uuid
  to           String    @db.VarChar(255)
  from         String    @db.VarChar(255)
  subject      String    @db.VarChar(255)
  templateType String?   @map("template_type") @db.VarChar(100)
  status       String    @db.VarChar(50)
  error        String?
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([to])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

model Image {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  datasetId        String?  @map("dataset_id") @db.Uuid
  originalFilename String   @map("original_filename") @db.VarChar(255)
  storageUrl       String   @map("storage_url")
  storagePath      String?  @map("storage_path")
  width            Int
  height           Int
  channels         Int      @default(3)
  fileSizeBytes    BigInt?  @map("file_size_bytes")
  format           String?  @db.VarChar(10)
  checksum         String?  @db.VarChar(64)
  uploadedBy       String?  @map("uploaded_by") @db.Uuid
  uploadedAt       DateTime @default(now()) @map("uploaded_at")
  publicId         String?  @map("public_id") @db.VarChar(255)
  dataset          Dataset? @relation(fields: [datasetId], references: [id])
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader         User?    @relation("ImageUploader", fields: [uploadedBy], references: [id])
  tasks            Task[]

  @@unique([projectId, datasetId, checksum])
  @@index([projectId])
  @@index([datasetId])
  @@index([checksum])
  @@map("images")
}

model Dataset {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  name            String   @db.VarChar(255)
  description     String?
  source          String?  @db.VarChar(100)
  sourceMetadata  Json?    @map("source_metadata")
  totalImages     Int      @default(0) @map("total_images")
  processedImages Int      @default(0) @map("processed_images")
  uploadedBy      String?  @map("uploaded_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader        User?    @relation("DatasetUploader", fields: [uploadedBy], references: [id])
  images          Image[]

  @@index([projectId])
  @@map("datasets")
}

model AnnotationConsensus {
  id                  String    @id @default(uuid()) @db.Uuid
  taskId              String    @unique @map("task_id") @db.Uuid
  finalAnnotations    Json      @map("final_annotations")
  consensusMethod     String    @map("consensus_method") @db.VarChar(50)
  sourceAssignmentIds String[]  @map("source_assignment_ids") @db.Uuid
  agreementScore      Float?    @map("agreement_score")
  isVerified          Boolean   @default(false) @map("is_verified")
  verifiedBy          String?   @map("verified_by") @db.Uuid
  verifiedAt          DateTime? @map("verified_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  task                Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  verifier            User?     @relation("ConsensusVerifier", fields: [verifiedBy], references: [id])

  @@index([isVerified])
  @@map("annotation_consensus")
}

model Export {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String   @map("project_id") @db.Uuid
  format              String   @db.VarChar(50)
  version             Int      @default(1)
  splitType           String?  @map("split_type") @db.VarChar(50)
  splitRatio          Json?    @map("split_ratio")
  filterCriteria      Json?    @map("filter_criteria")
  totalImages         Int?     @map("total_images")
  totalAnnotations    Int?     @map("total_annotations")
  classDistribution   Json?    @map("class_distribution")
  fileUrl             String   @map("file_url")
  fileSizeBytes       BigInt?  @map("file_size_bytes")
  checksum            String?  @db.VarChar(64)
  exportedBy          String   @map("exported_by") @db.Uuid
  downloadCount       Int      @default(0) @map("download_count")
  createdAt           DateTime @default(now()) @map("created_at")
  labelConfigSnapshot Json?    @map("label_config_snapshot")
  exporter            User     @relation("Exporter", fields: [exportedBy], references: [id])
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@index([format])
  @@map("exports")
}

model AiModel {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @db.VarChar(100)
  version         String           @db.VarChar(50)
  modelType       String           @map("model_type") @db.VarChar(50)
  config          Json?
  metrics         Json?
  isActive        Boolean          @default(true) @map("is_active")
  endpointUrl     String?          @map("endpoint_url")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  taskAssignments TaskAssignment[]

  @@index([isActive])
  @@map("ai_models")
}

model AssignmentRule {
  id                          String   @id @default(uuid()) @db.Uuid
  projectId                   String   @unique @map("project_id") @db.Uuid
  isAutoAssignEnabled         Boolean  @default(false) @map("is_auto_assign_enabled")
  assignmentStrategy          String   @default("ROUND_ROBIN") @map("assignment_strategy") @db.VarChar(50)
  autoAssignReviewer          Boolean  @default(true) @map("auto_assign_reviewer")
  reviewerAssignmentStrategy  String   @default("ROUND_ROBIN") @map("reviewer_assignment_strategy") @db.VarChar(50)
  reviewerDelayHours          Int      @default(0) @map("reviewer_delay_hours")
  maxTasksPerAnnotator        Int      @default(10) @map("max_tasks_per_annotator")
  maxTasksPerReviewer         Int      @default(20) @map("max_tasks_per_reviewer")
  minAnnotatorReputation      Float    @default(0) @map("min_annotator_reputation")
  minReviewerReputation       Float    @default(70) @map("min_reviewer_reputation")
  maxRejectionsBeforeReassign Int      @default(3) @map("max_rejections_before_reassign")
  autoReassignOnSkip          Boolean  @default(true) @map("auto_reassign_on_skip")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")
  project                     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("assignment_rules")
}

model UserWorkload {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  projectId          String    @map("project_id") @db.Uuid
  assignedTasks      Int       @default(0) @map("assigned_tasks")
  inProgressTasks    Int       @default(0) @map("in_progress_tasks")
  pendingReviewTasks Int       @default(0) @map("pending_review_tasks")
  maxConcurrentTasks Int       @default(10) @map("max_concurrent_tasks")
  availabilityStatus String    @default("AVAILABLE") @map("availability_status") @db.VarChar(50)
  lastAssignedAt     DateTime? @map("last_assigned_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([availabilityStatus, assignedTasks])
  @@map("user_workload")
}

model TaskReassignment {
  id             String   @id @default(uuid()) @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  oldAnnotatorId String?  @map("old_annotator_id") @db.Uuid
  newAnnotatorId String?  @map("new_annotator_id") @db.Uuid
  reason         String   @db.VarChar(100)
  reassignedBy   String   @map("reassigned_by") @db.Uuid
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  newAnnotator   User?    @relation("NewAnnotator", fields: [newAnnotatorId], references: [id])
  oldAnnotator   User?    @relation("OldAnnotator", fields: [oldAnnotatorId], references: [id])
  reassigner     User     @relation("Reassigner", fields: [reassignedBy], references: [id])
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([oldAnnotatorId])
  @@index([createdAt])
  @@map("task_reassignments")
}

model ProjectCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  projects    Project[]

  @@map("project_categories")
}

model LabelCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  color       String?  @db.VarChar(7)
  createdBy   String?  @map("created_by") @db.Uuid
  creator     User?    @relation("LabelCategoryCreator", fields: [createdBy], references: [id])
  labels      Label[]

  @@map("label_categories")
}

model Label {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(100)
  color         String         @db.VarChar(7)
  isGlobal      Boolean        @default(false) @map("is_global")
  categoryId    String?        @map("category_id") @db.Uuid
  createdBy     String?        @map("created_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")
  category      LabelCategory? @relation(fields: [categoryId], references: [id])
  creator       User?          @relation("LabelCreator", fields: [createdBy], references: [id])
  projectLabels ProjectLabel[]

  @@unique([name, categoryId])
  @@index([isGlobal])
  @@map("labels")
}

model ProjectLabel {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  labelId   String   @map("label_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, labelId])
  @@map("project_labels")
}

model LabelRequest {
  id             String             @id @default(uuid()) @db.Uuid
  projectId      String             @map("project_id") @db.Uuid
  requestedBy    String             @map("requested_by") @db.Uuid
  labelName      String             @map("label_name") @db.VarChar(100)
  suggestedColor String?            @map("suggested_color") @db.VarChar(7)
  reason         String?
  status         LabelRequestStatus @default(PENDING)
  reviewedBy     String?            @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?          @map("reviewed_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester      User               @relation("LabelRequester", fields: [requestedBy], references: [id])
  reviewer       User?              @relation("LabelReviewer", fields: [reviewedBy], references: [id])

  @@index([projectId, status])
  @@map("label_requests")
}

model TaskActivity {
  id        String     @id @default(uuid()) @db.Uuid
  taskId    String?    @map("task_id") @db.Uuid
  projectId String     @map("project_id") @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  action    TaskAction 
  metadata  Json?
  createdAt DateTime   @default(now()) @map("created_at")
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId, createdAt])
  @@index([userId])
  @@map("task_activities")
}

enum UserRole {
  ADMIN
  MANAGER
  REVIEWER
  ANNOTATOR
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectRole {
  MANAGER
  REVIEWER
  ANNOTATOR
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DifficultyLevel {
  EASY
  NORMAL
  HARD
  EXPERT_ONLY
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum AssignmentMethod {
  MANUAL
  AUTO_ROUND_ROBIN
  AUTO_LEAST_BUSY
  AUTO_SKILL_BASED
  AUTO_RANDOM
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  REJECTED
  APPROVED
  SKIPPED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REJECTED
  DEADLINE_WARNING
  COMMENT_MENTION
  SYSTEM_ANNOUNCEMENT
  SYSTEM_CHAT_CONFIG
  SYSTEM_USER_ROLE_CHANGE
  LABEL_REQUESTED
  LABEL_REQUEST_APPROVED
  LABEL_REQUEST_REJECTED
  LABEL_CREATED
  PROJECT_INVITATION
}

enum LabelRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskAction {
  CREATED
  ASSIGNED
  UNASSIGNED
  REASSIGNED
  DEADLINE_UPDATED
  STATUS_CHANGED
  SUBMITTED
  APPROVED
  REJECTED
  DELETED
  RESTORED
  BULK_ASSIGNED
  BULK_UNASSIGNED
  BULK_DELETED
}
